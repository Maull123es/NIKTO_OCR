# ═════════════════════════════════════════════════════════════════════════
# Nikto-OMR Configuration Template (.env.example)
# Copy this file to .env and fill in your actual values
# JANGAN COMMIT .env ke repository - hanya .env.example yang dicommit
# ═════════════════════════════════════════════════════════════════════════

# ─────────────────── TELEGRAM BOT CONFIGURATION ───────────────
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────── AI BACKEND CONFIGURATION ──────────────────
# Pilihan: "local" (Ollama), "gemini" (Google), "openai" (OpenAI)
AI_BACKEND=local

# Model lokal yang digunakan (pastikan sudah di-pull di Ollama)
OLLAMA_MODEL=qwen2.5vl:3b

# Host Ollama (default: localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ─────────────────── CLOUD API KEYS (FALLBACK) ────────────────
# Google Gemini API Key
# Dapatkan dari: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (fallback jika Gemini gagal)
# Dapatkan dari: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─────────────────── APPLICATION SETTINGS ─────────────────────
# Port untuk Flask web dashboard
FLASK_PORT=5001

# Debug mode (true/false)
FLASK_DEBUG=false

# ─────────────────── DIRECTORY SETTINGS ───────────────────────
# Direktori untuk menyimpan hasil scan
RESULTS_DIR=hasil_nilai

# Direktori untuk arsip gambar asli
ARCHIVE_DIR=arsip_scan

# Direktori untuk debug/crop images
DEBUG_DIR=debug_crop

# ═════════════════════════════════════════════════════════════════════════
# Setup Instructions:
# 1. Copy file ini menjadi .env: cp .env.example .env
# 2. Edit .env dan isi semua API keys dan tokens
# 3. Pastikan .env ditambahkan ke .gitignore
# 4. Jalankan aplikasi: python ocr.py atau python telegram_bot.py
# ═════════════════════════════════════════════════════════════════════════
